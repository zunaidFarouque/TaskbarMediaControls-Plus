{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-plus",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/TaskbarMediaControls.sln"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-plus",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/TaskbarMediaControls.csproj"
      ],
      "dependsOn": "build-plus",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test-plus",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/TaskbarMediaControls.sln"
      ],
      "group": "test",
      "problemMatcher": "$msCompile"
    }
  ]
}
